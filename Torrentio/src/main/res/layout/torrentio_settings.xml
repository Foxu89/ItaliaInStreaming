<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1E1E1E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Impostazioni Torrentio"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D3D3D"
        android:layout_marginBottom="16dp" />

    <!-- ── TORBOX ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TorBox"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <Switch
            android:id="@+id/torbox_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <EditText
        android:id="@+id/torbox_token"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Token API TorBox"
        android:inputType="text"
        android:padding="10dp"
        android:background="#2D2D2D"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D3D3D"
        android:layout_marginBottom="12dp" />

    <!-- ── REAL-DEBRID ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Real-Debrid"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <Switch
            android:id="@+id/realdebrid_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <EditText
        android:id="@+id/realdebrid_token"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API Key Real-Debrid"
        android:inputType="text"
        android:padding="10dp"
        android:background="#2D2D2D"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D3D3D"
        android:layout_marginBottom="12dp" />

    <!-- ── PREMIUMIZE ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Premiumize"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <Switch
            android:id="@+id/premiumize_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <EditText
        android:id="@+id/premiumize_token"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API Key Premiumize"
        android:inputType="text"
        android:padding="10dp"
        android:background="#2D2D2D"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D3D3D"
        android:layout_marginBottom="16dp" />

    <!-- ── SALVA ── -->
    <Button
        android:id="@+id/save_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Salva Impostazioni"
        android:textColor="#FFFFFF"
        android:background="#2D7D46"
        android:layout_marginBottom="8dp" />

</LinearLayout>
