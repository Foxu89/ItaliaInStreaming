<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:paddingVertical="4dp">

        <LinearLayout
            android:id="@+id/header_text_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/header_tw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/streamita_menu_title"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/header_build_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:alpha="0.78"
                android:maxLines="2"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/general_settings_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="68dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/general_settings_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/streamita_general_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/general_settings_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.8"
                android:text="@string/streamita_general_summary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/general_settings_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/streamita_open_action"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/extractors_settings_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="68dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/extractors_settings_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/streamita_extractors_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/extractors_settings_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.8"
                android:text="@string/streamita_extractors_summary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/extractors_settings_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/streamita_open_action"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ui_settings_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="68dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/ui_settings_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/streamita_ui_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ui_settings_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.8"
                android:text="@string/streamita_ui_summary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/ui_settings_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/streamita_open_action"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/advanced_settings_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="68dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/advanced_settings_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/streamita_advanced_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/advanced_settings_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.8"
                android:text="@string/streamita_advanced_summary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/advanced_settings_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/streamita_open_action"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
