<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- Header con titolo e bottone chiudi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#2D2D2D"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/guide_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Guida Rapida"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/close_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"
            android:contentDescription="Chiudi" />
    </LinearLayout>

    <!-- Divisore -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D3D3D" />

    <!-- ScrollView normale -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

        <TextView
            android:id="@+id/guide_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#DDDDDD"
            android:textColorLink="#4DA6FF"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:text="Caricamento guida in corso..." />
    </ScrollView>

    <!-- Divisore -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D3D3D" />

    <!-- Bottone GitHub -->
    <Button
        android:id="@+id/github_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Apri su GitHub"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="#238636"
        android:drawableStart="@drawable/telegram"
        android:drawablePadding="8dp"
        android:padding="12dp" />

</LinearLayout>
