    <CheckBox
        android:id="@+id/section_checkbox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Nome estensione"
        android:textSize="15sp"
        android:focusable="false" />
</LinearLayout>
